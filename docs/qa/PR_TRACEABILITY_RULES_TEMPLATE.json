{
  "requirements": [
    {
      "source": "docs/FRONTEND_GITHUB_ISSUES.md",
      "requirement": "FE-701 CI runs unit/integration/e2e suites",
      "scope": "diff",
      "patterns": [
        "suite: unit",
        "suite: integration",
        "suite: e2e"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_GITHUB_ISSUES.md",
      "requirement": "FE-701 suite commands are mapped in CI",
      "scope": "diff",
      "patterns": [
        "npm run test:unit",
        "npm run test:integration",
        "npm run test:e2e"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_CONVERSION_BACKLOG.md",
      "requirement": "Unit/integration stack uses Vitest + RTL + MSW",
      "scope": "diff",
      "patterns": [
        "\"vitest\"",
        "\"@testing-library/react\"",
        "\"msw\""
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_CONVERSION_BACKLOG.md",
      "requirement": "E2E stack uses Playwright",
      "scope": "diff",
      "patterns": [
        "\"@playwright/test\"",
        "playwright test"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_WEEK10_EXECUTION_PLAN.md",
      "requirement": "Required FE-701 check names are documented",
      "scope": "diff",
      "patterns": [
        "`frontend / unit`",
        "`frontend / integration`",
        "`frontend / e2e`"
      ],
      "on_missing": "FAIL"
    }
  ]
}
