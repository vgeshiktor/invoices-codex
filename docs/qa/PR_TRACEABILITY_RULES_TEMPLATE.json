{
  "requirements": [
    {
      "source": "docs/FRONTEND_GITHUB_ISSUES.md",
      "requirement": "FE-401 report creation flow is available in the reports route",
      "scope": "diff",
      "patterns": [
        "ReportCreationScreen",
        "path=\"/reports\"",
        "Create report"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_WEEK6_EXECUTION_PLAN.md",
      "requirement": "FE-401 format selection supports report output formats",
      "scope": "diff",
      "patterns": [
        "REPORT_FORMATS = ['json', 'csv', 'summary_csv', 'pdf']",
        "Output formats",
        "Summary CSV (.csv)"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_WEEK6_EXECUTION_PLAN.md",
      "requirement": "FE-401 includes loading, empty, and error states",
      "scope": "diff",
      "patterns": [
        "Loading reports...",
        "No reports created yet.",
        "Could not create report"
      ],
      "on_missing": "FAIL"
    },
    {
      "source": "docs/FRONTEND_GITHUB_ISSUES.md",
      "requirement": "FE-401 includes happy-path and failure-path integration tests",
      "scope": "diff",
      "patterns": [
        "submits report request with selected formats and parsed filters",
        "shows API error details when report creation fails"
      ],
      "on_missing": "FAIL"
    }
  ]
}
